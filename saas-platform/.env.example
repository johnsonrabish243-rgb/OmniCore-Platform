# ──────────────────────────────────────────────
# OmniCore ERP - Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# Get these credentials from your InsForge project dashboard:
#   - URL: .insforge/project.json → oss_host
#   - ANON_KEY: run `npx @insforge/cli secrets get ANON_KEY`
#   - API_KEY: run `npx @insforge/cli secrets get API_KEY`
# ──────────────────────────────────────────────

# InsForge Platform (required for auth, database, storage)
NEXT_PUBLIC_INSFORGE_URL=https://your-project-id.us-east.insforge.app
NEXT_PUBLIC_INSFORGE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...
INSFORGE_API_KEY=your-full-access-api-key-here
