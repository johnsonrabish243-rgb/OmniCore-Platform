# ─── OmniCore ERP — Environment Variables ───
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Database
# For local development: SQLite file-based
DATABASE_URL="file:./dev.db"
# For Vercel/Production: Use Turso (serverless SQLite) or PostgreSQL/Neon
# DATABASE_URL="libsql://your-db.turso.io?authToken=your-token"
# DATABASE_URL="postgresql://user:password@host:5432/db"

# Authentication
# Generate a strong random secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-strong-random-secret-here-min-32-chars"

# AI Assistant (Vercel AI SDK)
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-your-openai-api-key"

# In production on Vercel, set these in the Vercel Dashboard:
# - DATABASE_URL
# - NEXTAUTH_SECRET
# - OPENAI_API_KEY

# Optional: Email (for password reset & invitations)
# RESEND_API_KEY="re_..."
# SMTP_HOST="smtp.sendgrid.net"
# SMTP_PORT=587
# SMTP_USER="apikey"
# SMTP_PASS="your-sendgrid-api-key"
