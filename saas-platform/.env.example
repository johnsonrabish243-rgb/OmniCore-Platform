# --- OmniCore ERP --- Environment Variables ---
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# For Vercel deployment, set these in the Vercel Dashboard:
# Settings -> Environment Variables

# --- InsForge (Backend, Auth, Database) ---
# Get these from: npx @insforge/cli secrets get ANON_KEY
# Or from the InsForge console dashboard
NEXT_PUBLIC_INSFORGE_URL=https://your-app-key.region.insforge.app
NEXT_PUBLIC_INSFORGE_ANON_KEY=anon_your_anon_key_here
INSFORGE_API_KEY=ik_your_api_key_here

# --- Site URL (used for auth redirects & OAuth callbacks) ---
# For local dev:
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# For Vercel production:
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# --- Authentication ---
# Generate a strong random secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-strong-random-secret-here-min-32-chars"

# --- AI Assistant (Vercel AI SDK) ---
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-your-openai-api-key"

# --- Email (for password reset & invitations) ---
# Get your Resend API key from https://resend.com
RESEND_API_KEY="re_your_resend_api_key_here"

# --- Vercel Deployment ---
# In the Vercel Dashboard, set these environment variables:
#   NEXT_PUBLIC_INSFORGE_URL     - Your InsForge backend URL
#   NEXT_PUBLIC_INSFORGE_ANON_KEY - Your InsForge anonymous key
#   INSFORGE_API_KEY             - Your InsForge API key
#   NEXTAUTH_SECRET              - Random secret for auth
#   OPENAI_API_KEY               - OpenAI API key for AI features
#   RESEND_API_KEY               - Resend API key for emails
#   NEXT_PUBLIC_SITE_URL         - Your production domain URL
